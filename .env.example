# Optional: for cron route protection
CRON_SECRET=

# Optional: Stripe price id fallback (recommended to set in admin settings instead)
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_CLUB=
